# Copy this file to .env and fill in the values before running docker compose.
# Never commit .env to version control.

# OpenAI API key — get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# PostgreSQL credentials (used by both the db and app containers)
DB_USER=postgres
DB_PASSWORD=changeme

# PostgreSQL connection parts (used in prod / Render — constructed into jdbc:postgresql://DB_HOST:DB_PORT/DB_NAME)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=tcgen
